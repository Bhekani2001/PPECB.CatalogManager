@model PPECB.CatalogManager.Core.Entities.ProductImage

@{
    ViewData["Title"] = "View Image";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2>Image Details</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Images
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">@(Model.Product?.Name ?? "Product Image")</h4>
                </div>
                <div class="card-body text-center">
                    @if (Model.ImageData != null)
                    {
                        <img src="data:@Model.ImageMimeType;base64,@Convert.ToBase64String(Model.ImageData)" class="img-fluid rounded" style="max-height: 400px;" />
                    }
                    else
                    {
                        <p>No image data available</p>
                    }
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Product:</dt>
                        <dd class="col-sm-8">@(Model.Product?.Name ?? "Unknown")</dd>

                        <dt class="col-sm-4">File Name:</dt>
                        <dd class="col-sm-8">@Model.FileName</dd>

                        <dt class="col-sm-4">File Size:</dt>
                        <dd class="col-sm-8">@(Model.FileSize / 1024) KB</dd>

                        <dt class="col-sm-4">Dimensions:</dt>
                        <dd class="col-sm-8">@(Model.Width.HasValue ? $"{Model.Width} x {Model.Height} px" : "Unknown")</dd>

                        <dt class="col-sm-4">Alt Text:</dt>
                        <dd class="col-sm-8">@(Model.AltText ?? "None")</dd>

                        <dt class="col-sm-4">Primary Image:</dt>
                        <dd class="col-sm-8">@(Model.IsPrimary ? "Yes" : "No")</dd>

                        <dt class="col-sm-4">Uploaded By:</dt>
                        <dd class="col-sm-8">@Model.CreatedBy</dd>

                        <dt class="col-sm-4">Uploaded Date:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>