@model PPECB.CatalogManager.Core.DTOs.CreateWarehouseDto

@{
    ViewData["Title"] = "Create Warehouse";
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0">Create Warehouse</h2>
                    <p class="text-muted mt-1">Add a new storage location</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Warehouses
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-building"></i> Warehouse Information</h4>
                </div>
                <div class="card-body">
                    <form asp-action="ProcessCreateWarehouse" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Code" class="form-label fw-semibold">Warehouse Code *</label>
                                <input asp-for="Code" class="form-control" placeholder="e.g., WH001" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Warehouse Name *</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Main Warehouse" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-semibold">Location</label>
                            <input asp-for="Location" class="form-control" placeholder="City or area" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Full street address"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ManagerName" class="form-label fw-semibold">Manager Name</label>
                                <input asp-for="ManagerName" class="form-control" placeholder="Full name" />
                                <span asp-validation-for="ManagerName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="Phone" class="form-control" placeholder="Contact number" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create Warehouse
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}