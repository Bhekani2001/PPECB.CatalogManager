@model PPECB.CatalogManager.Core.DTOs.CreateSupplierDto

@{
    ViewData["Title"] = "Create Supplier";
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0">Create Supplier</h2>
                    <p class="text-muted mt-1">Add a new supplier to your catalog</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Suppliers
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-truck"></i> Supplier Information</h4>
                </div>
                <div class="card-body">
                    <form asp-action="ProcessCreateSupplier" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Code" class="form-label fw-semibold">Supplier Code *</label>
                                <input asp-for="Code" class="form-control" placeholder="e.g., SUP001" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                                <div class="form-text">Unique identifier for the supplier</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Supplier Name *</label>
                                <input asp-for="Name" class="form-control" placeholder="Company name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ContactPerson" class="form-label fw-semibold">Contact Person</label>
                            <input asp-for="ContactPerson" class="form-control" placeholder="Full name" />
                            <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="contact@supplier.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="Phone" class="form-control" placeholder="+27 12 345 6789" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Street address, city, postal code"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TaxNumber" class="form-label fw-semibold">Tax / VAT Number</label>
                            <input asp-for="TaxNumber" class="form-control" placeholder="e.g., VAT123456789" />
                            <span asp-validation-for="TaxNumber" class="text-danger small"></span>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create Supplier
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}