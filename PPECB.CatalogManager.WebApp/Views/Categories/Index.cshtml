@model IEnumerable<PPECB.CatalogManager.Core.DTOs.CategoryDto>

@{
    ViewData["Title"] = "Categories";
}

<h1>Categories</h1>

<p>
    <a asp-action="ShowCreateCategoryForm" class="btn btn-primary">Create New Category</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Description</th>
            <th>Active</th>
            <th>Display Order</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Code</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>@item.DisplayOrder</td>
                <td>
                    <a asp-action="GetCategoryDetails" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="ShowEditCategoryForm" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="ConfirmDeleteCategory" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>