@model PPECB.CatalogManager.Core.DTOs.BrandDto

@{
    ViewData["Title"] = "Brand Details";
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">Brand Details</h2>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Brands
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-tag"></i> @Model.Name</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Name:</dt>
                                <dd class="col-sm-8">@Model.Name</dd>

                                <dt class="col-sm-4">Description:</dt>
                                <dd class="col-sm-8">@(Model.Description ?? "N/A")</dd>

                                <dt class="col-sm-4">Website:</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.Website))
                                    {
                                        <a href="@Model.Website" target="_blank">@Model.Website</a>
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Logo:</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                                    {
                                        <img src="@Model.LogoUrl" alt="@Model.Name" style="max-height: 100px;" />
                                    }
                                    else
                                    {
                                        <span>No logo</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Status:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Products:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-primary">@Model.ProductCount products</span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Created: @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") by @Model.CreatedBy</small>
                        </div>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div class="col-md-6 text-end">
                                <small class="text-muted">Last updated: @Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") by @Model.UpdatedBy</small>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="ShowEditBrandForm" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="ConfirmDeleteBrand" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>