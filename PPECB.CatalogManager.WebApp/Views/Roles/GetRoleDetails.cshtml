@model PPECB.CatalogManager.Core.Entities.Role

@{
    ViewData["Title"] = "Role Details";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2>Role Details</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Roles
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">@Model.Name</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Role Name:</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Description:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "No description")</dd>

                        <dt class="col-sm-4">System Role:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsSystemRole)
                            {
                                <span class="badge bg-info">System Role</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Custom Role</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Created Date:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-4">Created By:</dt>
                        <dd class="col-sm-8">@(Model.CreatedBy ?? "System")</dd>

                        @if (Model.UpdatedAt.HasValue)
                        {
                            <dt class="col-sm-4">Last Updated:</dt>
                            <dd class="col-sm-8">@Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>

                            <dt class="col-sm-4">Updated By:</dt>
                            <dd class="col-sm-8">@(Model.UpdatedBy ?? "Unknown")</dd>
                        }
                    </dl>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-end gap-2">
                        @if (!Model.IsSystemRole)
                        {
                            <a asp-action="ShowEditRoleForm" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                            <a asp-action="ConfirmDeleteRole" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>