@{
    ViewData["Title"] = "Remove Stock";
    var products = ViewBag.Products as IEnumerable<PPECB.CatalogManager.Core.DTOs.ProductDto>;
    var warehouses = ViewBag.Warehouses as IEnumerable<PPECB.CatalogManager.Core.DTOs.WarehouseDto>;
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0">Remove Stock</h2>
                    <p class="text-muted mt-1">Decrease inventory quantity</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Transactions
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-dash-circle"></i> Remove Stock</h4>
                </div>
                <div class="card-body">
                    <form asp-action="ProcessRemoveStock" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product *</label>
                            <select name="productId" id="productId" class="form-select" required>
                                <option value="">-- Select Product --</option>
                                @if (products != null)
                                {
                                    foreach (var product in products)
                                    {
                                        <option value="@product.Id" data-stock="@product.StockQuantity">@product.Code - @product.Name (Stock: @product.StockQuantity)</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Current Stock</label>
                            <input type="text" id="currentStock" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Quantity to Remove *</label>
                            <input type="number" name="quantity" id="quantity" class="form-control" min="1" required />
                            <div id="stockWarning" class="text-danger small mt-1"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Warehouse</label>
                            <select name="warehouseId" class="form-select">
                                <option value="">-- Select Warehouse (Optional) --</option>
                                @if (warehouses != null)
                                {
                                    foreach (var warehouse in warehouses)
                                    {
                                        <option value="@warehouse.Id">@warehouse.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reference Number</label>
                            <input type="text" name="referenceNumber" class="form-control" placeholder="Order Number, Invoice, etc." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reason for Removal</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="e.g., Sold, Damaged, Expired, etc."></textarea>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger" id="removeStockButton" disabled>
                                <i class="bi bi-check-circle"></i> Remove Stock
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('productId').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var stock = selectedOption.getAttribute('data-stock');
        document.getElementById('currentStock').value = stock || 0;
    });

    document.getElementById('quantity').addEventListener('input', function() {
        var currentStock = parseInt(document.getElementById('currentStock').value) || 0;
        var quantity = parseInt(this.value) || 0;
        var warning = document.getElementById('stockWarning');

        if (quantity > currentStock) {
            warning.innerHTML = 'Warning: Quantity exceeds current stock!';
        } else {
            warning.innerHTML = '';
        }
    });
</script>